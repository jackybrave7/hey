{
  "name": "hey-messenger",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=web\"",
    "build": "npm run build --workspace=web",
    "start": "node server/src/index.js",
    "install:all": "npm install && npm install --workspace=server && npm install --workspace=web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
