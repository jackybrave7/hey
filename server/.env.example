# Режим хранения медиафайлов: local (разработка) | s3 (продакшн)
STORAGE_MODE=local

# S3 настройки TimeWeb Cloud Storage (только для STORAGE_MODE=s3)
# Получить ключи: https://timeweb.cloud → S3 хранилище → API ключи
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=heymessenger
S3_ACCESS_KEY=YOUR_ACCESS_KEY_HERE
S3_SECRET_KEY=YOUR_SECRET_KEY_HERE
S3_PUBLIC_URL_BASE=https://s3.twcstorage.ru/heymessenger
